---
import { formatDate } from "../utils/formatDate";

interface Props {
  title: string;
  date: Date;
  slug: string;
  tags?: string[];
  basePath?: string;
  refIndex?: number;
}

const { title, date, slug, tags, basePath = "/blog", refIndex } = Astro.props;
---

<a href={`${basePath}/${slug}`} class="group flex gap-3 py-2.5 leading-relaxed">
  {refIndex !== undefined && (
    <span class="shrink-0 text-primary-600 dark:text-primary-400 tabular-nums">[{refIndex}]</span>
  )}
  <span class="min-w-0">
    <span class="font-semibold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">{title}.</span>
    <time datetime={date.toISOString()} class="text-gray-500 dark:text-gray-400"> {formatDate(date)}.</time>
    {tags?.[0] && <span class="italic text-gray-500 dark:text-gray-400"> {tags[0].toLowerCase()}.</span>}
  </span>
</a>
