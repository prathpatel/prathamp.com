---
import { formatDate } from "../utils/formatDate";

interface Props {
  title: string;
  date: Date;
  slug: string;
  tags?: string[];
  basePath?: string;
}

const { title, date, slug, tags, basePath = "/blog" } = Astro.props;
---

<a
  href={`${basePath}/${slug}`}
  class="group grid grid-cols-[1fr_auto] md:grid-cols-12 items-baseline gap-x-4 gap-y-1.5 py-5 md:py-6 border-b border-gray-200 dark:border-gray-800 transition-colors"
>
  <time
    datetime={date.toISOString()}
    class="order-last md:order-none col-span-2 md:col-span-2 text-[10px] font-medium uppercase tracking-[0.15em] text-gray-500 dark:text-gray-400"
  >
    {formatDate(date)}
  </time>
  <h3 class="min-w-0 md:col-span-7 font-display text-lg md:text-2xl font-medium tracking-tight text-gray-900 dark:text-white transition-all duration-300 group-hover:text-primary-600 dark:group-hover:text-primary-400">
    {title}
  </h3>
  <span class="hidden md:block md:col-span-2 text-right text-[10px] font-medium uppercase tracking-[0.15em] text-gray-500 dark:text-gray-400">
    {tags?.[0]}
  </span>
  <svg
    class="md:col-span-1 justify-self-end w-5 h-5 shrink-0 self-center md:self-auto text-gray-300 dark:text-gray-700 transition-all duration-300 group-hover:text-primary-600 dark:group-hover:text-primary-400"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M9 7h8v8" />
  </svg>
</a>
