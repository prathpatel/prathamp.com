---
import { formatDate } from "../utils/formatDate";
import Tag from "./Tag.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags } = Astro.props;
---

<a
  href={`/blog/${slug}`}
  class="blog-card group flex flex-col rounded-2xl border border-gray-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-gray-300 hover:shadow-xl hover:shadow-gray-900/5 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-gray-700 dark:hover:shadow-black/30"
>
  <div class="blog-card__meta mb-3 flex items-center gap-4 font-mono text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
    <time datetime={date.toISOString()}>{formatDate(date)}</time>
  </div>
  <div class="blog-card__body flex-1">
    <h3 class="blog-card__title mb-2 text-xl font-semibold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-gray-100 dark:group-hover:text-primary-400">
      {title}
    </h3>
    <p class="blog-card__description mb-4 line-clamp-2 text-gray-600 dark:text-gray-400">{description}</p>
  </div>
  {tags && (
    <div class="blog-card__tags flex flex-wrap gap-2">
      {tags.slice(0, 3).map((tag) => <Tag name={tag} size="sm" asLink={false} />)}
    </div>
  )}
</a>
