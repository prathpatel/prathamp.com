---
import Tag from "./Tag.astro";

interface Props {
  title: string;
  description: string;
  tech: string[];
  slug: string;
  featured?: boolean;
  image?: string;
}

const { title, description, tech, slug, featured, image } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class:list={[
    "group flex flex-col bg-white dark:bg-gray-900 rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 hover:-translate-y-1 hover:shadow-xl hover:shadow-gray-900/5 dark:hover:shadow-black/30 transition-all duration-300",
    featured && "md:col-span-2",
  ]}
>
  {image && (
    <div class="aspect-video bg-gray-100 dark:bg-gray-800 overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>
  )}
  <div class="p-6 flex flex-col flex-1">
    <h3 class="flex items-start justify-between gap-3 text-xl font-semibold text-gray-900 dark:text-gray-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-2">
      <span>{title}</span>
      <svg
        class="w-5 h-5 mt-1 shrink-0 text-gray-300 dark:text-gray-600 group-hover:text-primary-600 dark:group-hover:text-primary-400 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M9 7h8v8" />
      </svg>
    </h3>
    <p class="text-gray-600 dark:text-gray-400 mb-4 line-clamp-2 flex-1">{description}</p>
    <div class="flex flex-wrap gap-2">
      {tech.slice(0, 4).map((t) => <Tag name={t} size="sm" asLink={false} />)}
    </div>
  </div>
</a>
