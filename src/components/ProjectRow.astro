---
interface Props {
  title: string;
  description: string;
  tech: string[];
  slug: string;
  index?: string;
}

const { title, description, tech, slug, index } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class="group grid grid-cols-[1fr_auto] md:grid-cols-12 items-start md:items-baseline gap-x-4 gap-y-3 py-7 md:py-9 border-b border-gray-200 dark:border-gray-800 transition-colors"
>
  {index && (
    <span class="hidden md:block md:col-span-1 font-mono text-sm text-gray-400 dark:text-gray-600 transition-colors group-hover:text-primary-600 dark:group-hover:text-primary-400">
      {index}
    </span>
  )}
  <div class:list={["min-w-0", index ? "md:col-span-7" : "md:col-span-8"]}>
    <h3 class="font-display text-2xl md:text-4xl font-semibold tracking-tight text-gray-900 dark:text-white transition-all duration-300 group-hover:translate-x-2 group-hover:text-primary-600 dark:group-hover:text-primary-400">
      {title}
    </h3>
    <p class="mt-2 max-w-xl text-gray-600 dark:text-gray-400 line-clamp-2 md:line-clamp-1">
      {description}
    </p>
  </div>
  <div class="hidden md:block md:col-span-3 font-mono text-xs lowercase tracking-wide text-gray-500 dark:text-gray-400">
    {tech.slice(0, 3).join(" · ")}
  </div>
  <svg
    class="md:col-span-1 justify-self-end w-6 h-6 md:w-7 md:h-7 shrink-0 text-gray-300 dark:text-gray-700 transition-all duration-300 group-hover:text-primary-600 dark:group-hover:text-primary-400 group-hover:translate-x-1 group-hover:-translate-y-1"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M9 7h8v8" />
  </svg>
  <div class="md:hidden col-span-2 font-mono text-xs lowercase tracking-wide text-gray-500 dark:text-gray-400">
    {tech.slice(0, 3).join(" · ")}
  </div>
</a>
