---
import { siteConfig } from "../config/site";

const socials = [
  { name: "GitHub", href: `https://github.com/${siteConfig.author.github}` },
  { name: "LinkedIn", href: `https://linkedin.com/in/${siteConfig.author.linkedin}` },
  { name: "Twitter", href: `https://twitter.com/${siteConfig.author.twitter}` },
];
---

<footer class="mt-16 border-t-3 border-double border-gray-900 dark:border-gray-100 bg-white dark:bg-gray-950">
  <div class="max-w-5xl mx-auto px-4 py-12 md:py-16 text-center">
    <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Correspondence</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-1">
      All inquiries should be addressed to
    </p>
    <a
      href={`mailto:${siteConfig.author.email}`}
      class="text-xl md:text-2xl font-semibold text-primary-600 dark:text-primary-400 hover:underline underline-offset-4"
    >
      {siteConfig.author.email}
    </a>

    <div class="mt-8 flex flex-wrap justify-center gap-x-2 text-sm text-gray-600 dark:text-gray-400">
      {socials.map((s, i) => (
        <span>
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary-600 dark:text-primary-400 hover:underline underline-offset-2"
          >{s.name}&#8599;</a>{i < socials.length - 1 && <span aria-hidden="true"> ·</span>}
        </span>
      ))}
    </div>

    <nav class="mt-6 flex flex-wrap justify-center gap-x-2 text-sm italic text-gray-500 dark:text-gray-400">
      {siteConfig.nav.map((item, i) => (
        <span>
          <a href={item.href} class="hover:text-primary-600 dark:hover:text-primary-400 hover:underline underline-offset-2">
            {item.name}
          </a>{i < siteConfig.nav.length - 1 && <span aria-hidden="true"> ·</span>}
        </span>
      ))}
    </nav>

    <p class="mt-10 text-xs text-gray-400 dark:text-gray-600">
      &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved. Typeset in STIX Two, after LaTeX.
    </p>
  </div>
</footer>
