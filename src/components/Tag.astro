---
interface Props {
  name: string;
  size?: "sm" | "md";
  asLink?: boolean;
  basePath?: string;
}

const { name, size = "md", asLink = true, basePath = "/tags" } = Astro.props;

const sizeClasses = {
  sm: "text-xs",
  md: "text-sm",
};

const baseClasses = "inline-block italic text-gray-500 dark:text-gray-400 transition-colors";
const hoverClasses = asLink ? "hover:text-primary-600 dark:hover:text-primary-400 hover:underline underline-offset-2" : "";
---

{asLink ? (
  <a
    href={`${basePath}/${name.toLowerCase()}`}
    class:list={[baseClasses, hoverClasses, sizeClasses[size]]}
  >[{name}]</a>
) : (
  <span class:list={[baseClasses, sizeClasses[size]]}>[{name}]</span>
)}
