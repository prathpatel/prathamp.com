---
interface Props {
  name: string;
  size?: "sm" | "md";
  asLink?: boolean;
  basePath?: string;
}

const { name, size = "md", asLink = true, basePath = "/tags" } = Astro.props;

const sizeClasses = {
  sm: "text-[10px] px-2 py-1",
  md: "text-[11px] px-2.5 py-1",
};

const baseClasses = "inline-block font-medium uppercase tracking-[0.15em] border border-gray-300 text-gray-600 transition-colors dark:border-gray-700 dark:text-gray-400";
const hoverClasses = asLink ? "hover:border-primary-600 hover:text-primary-600 dark:hover:border-primary-400 dark:hover:text-primary-400" : "";
---

{asLink ? (
  <a
    href={`${basePath}/${name.toLowerCase()}`}
    class:list={[baseClasses, hoverClasses, sizeClasses[size]]}
  >
    {name}
  </a>
) : (
  <span class:list={[baseClasses, sizeClasses[size]]}>
    {name}
  </span>
)}
