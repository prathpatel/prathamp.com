---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectRow from "../components/ProjectRow.astro";
import PostRow from "../components/PostRow.astro";
import { getCollection } from "astro:content";

const featuredProjects = (await getCollection("projects"))
  .filter((p) => p.data.featured && !p.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 4);

const latestPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 5);
---

<BaseLayout>
  <!-- Hero: asymmetric grid cells -->
  <section class="grid md:grid-cols-12 border-b border-gray-200 dark:border-gray-800">
    <div class="md:col-span-8 p-4 py-14 md:p-10 md:py-24 md:border-r border-gray-200 dark:border-gray-800">
      <h1 class="text-6xl md:text-8xl font-bold tracking-tight leading-[0.95] text-gray-950 dark:text-white">
        Pratham<br />Patel<span class="inline-block w-[0.13em] h-[0.13em] ml-[0.06em] bg-primary-600" aria-hidden="true"></span>
      </h1>
    </div>
    <div class="md:col-span-4 flex flex-col justify-between gap-10 p-4 py-8 md:p-10 border-t md:border-t-0 border-gray-200 dark:border-gray-800">
      <div class="flex items-center gap-2.5 text-[11px] font-medium uppercase tracking-[0.18em] text-gray-700 dark:text-gray-300">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 bg-emerald-500"></span>
        </span>
        Open to opportunities
      </div>
      <dl class="space-y-3 text-[11px] font-medium uppercase tracking-[0.18em]">
        <div class="flex justify-between gap-4 border-b border-gray-200 dark:border-gray-800 pb-2">
          <dt class="text-gray-400 dark:text-gray-600">Role</dt>
          <dd class="text-gray-950 dark:text-white text-right">Data Scientist</dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-gray-200 dark:border-gray-800 pb-2">
          <dt class="text-gray-400 dark:text-gray-600">Focus</dt>
          <dd class="text-gray-950 dark:text-white text-right">ML · NLP · CV</dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-gray-200 dark:border-gray-800 pb-2">
          <dt class="text-gray-400 dark:text-gray-600">Stack</dt>
          <dd class="text-gray-950 dark:text-white text-right">AWS · EKS · Docker</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400 dark:text-gray-600">Base</dt>
          <dd class="text-gray-950 dark:text-white text-right">Ahmedabad, IN</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Profile strip -->
  <section class="grid md:grid-cols-12 border-b border-gray-200 dark:border-gray-800">
    <div class="md:col-span-4 p-4 md:p-10 md:border-r border-gray-200 dark:border-gray-800">
      <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-primary-600 dark:text-primary-400">Profile</p>
    </div>
    <div class="md:col-span-8 p-4 pb-8 md:p-10">
      <p class="text-lg md:text-xl leading-relaxed text-gray-700 dark:text-gray-300 max-w-2xl">
        2+ years of experience shipping production ML systems, NLP pipelines, and computer vision solutions on cloud-native infrastructure. I translate business problems into deployed AI products — and mentor the next generation of engineers along the way.
      </p>
    </div>
  </section>

  <!-- Selected Work -->
  {featuredProjects.length > 0 && (
    <section class="border-b border-gray-200 dark:border-gray-800">
      <div class="flex items-center justify-between px-4 md:px-10 py-3 border-b border-gray-200 dark:border-gray-800">
        <h2 class="text-[11px] font-medium uppercase tracking-[0.2em] text-gray-950 dark:text-white">Selected Work</h2>
        <span class="text-[11px] font-medium tracking-[0.2em] text-primary-600 dark:text-primary-400">01</span>
      </div>
      <div class="px-4 md:px-10">
        {featuredProjects.map((project, i) => (
          <ProjectRow
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            slug={project.slug}
            index={String(i + 1).padStart(2, "0")}
          />
        ))}
      </div>
      <a
        href="/projects"
        class="flex items-center justify-between px-4 md:px-10 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
      >
        All projects
        <span>&rarr;</span>
      </a>
    </section>
  )}

  <!-- Writing -->
  {latestPosts.length > 0 && (
    <section>
      <div class="flex items-center justify-between px-4 md:px-10 py-3 border-b border-gray-200 dark:border-gray-800">
        <h2 class="text-[11px] font-medium uppercase tracking-[0.2em] text-gray-950 dark:text-white">Writing</h2>
        <span class="text-[11px] font-medium tracking-[0.2em] text-primary-600 dark:text-primary-400">02</span>
      </div>
      <div class="px-4 md:px-10">
        {latestPosts.map((post) => (
          <PostRow
            title={post.data.title}
            date={post.data.date}
            slug={post.slug}
            tags={post.data.tags}
          />
        ))}
      </div>
      <a
        href="/blog"
        class="flex items-center justify-between px-4 md:px-10 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
      >
        All writing
        <span>&rarr;</span>
      </a>
    </section>
  )}
</BaseLayout>
