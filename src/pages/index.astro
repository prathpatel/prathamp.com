---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectRow from "../components/ProjectRow.astro";
import PostRow from "../components/PostRow.astro";
import { getCollection } from "astro:content";

const featuredProjects = (await getCollection("projects"))
  .filter((p) => p.data.featured && !p.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 4);

const latestPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 5);
---

<BaseLayout>
  <!-- Title block -->
  <section class="max-w-3xl mx-auto px-4 pt-14 md:pt-20 text-center">
    <p class="text-sm italic text-primary-600 dark:text-primary-400 mb-8">
      Preprint &middot; Open to opportunities
    </p>
    <h1 class="text-3xl md:text-[2.75rem] font-bold leading-tight md:leading-[1.2] text-gray-900 dark:text-white [text-wrap:balance]">
      Shipping Production Machine Learning: NLP&nbsp;Pipelines, Computer Vision &amp; Cloud&#8209;Native AI&nbsp;Systems
    </h1>
    <p class="mt-7 text-lg text-gray-900 dark:text-gray-100">
      Pratham Patel<sup class="text-primary-600 dark:text-primary-400">1</sup>
    </p>
    <p class="mt-1.5 text-sm text-gray-500 dark:text-gray-400">
      <sup>1</sup>&thinsp;Data Scientist, Ahmedabad, India &middot;
      <a href="mailto:prathammpatel@outlook.com" class="text-primary-600 dark:text-primary-400 hover:underline underline-offset-2">prathammpatel@outlook.com</a>
    </p>
  </section>

  <!-- Abstract -->
  <section class="max-w-2xl mx-auto px-4 mt-12">
    <h2 class="text-center text-base font-bold text-gray-900 dark:text-white mb-3">Abstract</h2>
    <p class="text-justify [hyphens:auto] leading-relaxed text-gray-800 dark:text-gray-200">
      Data Scientist with 2+ years of experience shipping production ML systems, NLP pipelines, and computer vision solutions on cloud-native infrastructure (AWS, EKS, Docker). This work demonstrates the translation of business problems into deployed AI products — including an enterprise no-code ML platform, AI meeting intelligence, and manufacturing defect detection — while mentoring the next generation of engineers along the way.
    </p>
    <p class="mt-4 text-sm text-gray-700 dark:text-gray-300">
      <span class="font-bold">Keywords:</span>
      <em>machine learning, NLP, computer vision, time series forecasting, AWS, mentorship</em>
    </p>
  </section>

  <!-- 1. Selected Work -->
  {featuredProjects.length > 0 && (
    <section class="max-w-3xl mx-auto px-4 mt-14 md:mt-20">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">
        <span class="mr-4">1</span>Selected Work
      </h2>
      <div class="divide-y divide-gray-200 dark:divide-gray-800">
        {featuredProjects.map((project, i) => (
          <ProjectRow
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            slug={project.slug}
            index={`1.${i + 1}`}
          />
        ))}
      </div>
      <p class="mt-4 text-sm italic">
        <a href="/projects" class="text-primary-600 dark:text-primary-400 hover:underline underline-offset-2">
          See all projects &rarr;
        </a>
      </p>
    </section>
  )}

  <!-- 2. Writing -->
  {latestPosts.length > 0 && (
    <section class="max-w-3xl mx-auto px-4 mt-14 md:mt-20 pb-8">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">
        <span class="mr-4">2</span>Writing
      </h2>
      <div>
        {latestPosts.map((post, i) => (
          <PostRow
            title={post.data.title}
            date={post.data.date}
            slug={post.slug}
            tags={post.data.tags}
            refIndex={i + 1}
          />
        ))}
      </div>
      <p class="mt-4 text-sm italic">
        <a href="/blog" class="text-primary-600 dark:text-primary-400 hover:underline underline-offset-2">
          Full bibliography &rarr;
        </a>
      </p>
    </section>
  )}
</BaseLayout>
