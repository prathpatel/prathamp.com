---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectRow from "../components/ProjectRow.astro";
import PostRow from "../components/PostRow.astro";
import { getCollection } from "astro:content";

const featuredProjects = (await getCollection("projects"))
  .filter((p) => p.data.featured && !p.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 4);

const latestPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 5);
---

<BaseLayout>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 pt-16 md:pt-24">
    <div class="flex items-center gap-2.5 font-mono text-xs md:text-sm text-gray-600 dark:text-gray-400 mb-8 md:mb-10">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
      </span>
      open to opportunities — ahmedabad, india
    </div>
    <h1 class="font-display font-bold uppercase tracking-tighter leading-[0.9] text-gray-900 dark:text-white text-[clamp(3.5rem,13vw,10rem)]">
      Pratham<br />Patel<span class="text-primary-600 dark:text-primary-400">.</span>
    </h1>
    <div class="mt-10 md:mt-16 grid gap-6 md:gap-8 md:grid-cols-12 border-t-2 border-gray-900 dark:border-gray-100 pt-8 md:pt-10">
      <div class="md:col-span-4 font-mono text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400 leading-loose">
        Data Scientist<br />
        ML · NLP · Computer Vision<br />
        AWS · EKS · Docker
      </div>
      <p class="md:col-span-8 text-xl md:text-2xl leading-relaxed text-gray-700 dark:text-gray-300">
        2+ years of experience shipping production ML systems, NLP pipelines, and computer vision solutions on cloud-native infrastructure. I translate business problems into deployed AI products — and mentor the next generation of engineers along the way.
      </p>
    </div>
  </section>

  <!-- Selected Work -->
  {featuredProjects.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 pt-20 md:pt-32">
      <div class="flex items-baseline justify-between pb-4 border-b-2 border-gray-900 dark:border-gray-100">
        <h2 class="font-display text-3xl md:text-5xl font-bold uppercase tracking-tight text-gray-900 dark:text-white">
          Selected Work
        </h2>
        <span class="font-mono text-sm text-primary-600 dark:text-primary-400">(01)</span>
      </div>
      <div>
        {featuredProjects.map((project, i) => (
          <ProjectRow
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            slug={project.slug}
            index={String(i + 1).padStart(2, "0")}
          />
        ))}
      </div>
      <a
        href="/projects"
        class="group flex items-center justify-between py-6 font-mono text-sm uppercase tracking-widest text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
      >
        all projects
        <span class="inline-block transition-transform group-hover:translate-x-2">&rarr;</span>
      </a>
    </section>
  )}

  <!-- Writing -->
  {latestPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 pt-20 md:pt-32 pb-20 md:pb-32">
      <div class="flex items-baseline justify-between pb-4 border-b-2 border-gray-900 dark:border-gray-100">
        <h2 class="font-display text-3xl md:text-5xl font-bold uppercase tracking-tight text-gray-900 dark:text-white">
          Writing
        </h2>
        <span class="font-mono text-sm text-primary-600 dark:text-primary-400">(02)</span>
      </div>
      <div>
        {latestPosts.map((post) => (
          <PostRow
            title={post.data.title}
            date={post.data.date}
            slug={post.slug}
            tags={post.data.tags}
          />
        ))}
      </div>
      <a
        href="/blog"
        class="group flex items-center justify-between py-6 font-mono text-sm uppercase tracking-widest text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
      >
        all writing
        <span class="inline-block transition-transform group-hover:translate-x-2">&rarr;</span>
      </a>
    </section>
  )}
</BaseLayout>
