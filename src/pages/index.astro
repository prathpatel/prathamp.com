---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BlogCard from "../components/BlogCard.astro";
import { siteConfig } from "../config/site";
import { getCollection } from "astro:content";

const featuredProjects = (await getCollection("projects"))
  .filter((p) => p.data.featured && !p.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .slice(0, 3);

const latestPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="relative max-w-6xl mx-auto px-4 pt-20 pb-24 md:pt-32 md:pb-32">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-32 right-0 h-96 w-96 rounded-full bg-primary-500/10 blur-3xl"
    >
    </div>
    <div class="relative max-w-3xl">
      <div class="inline-flex items-center gap-2.5 rounded-full border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 px-3.5 py-1.5 font-mono text-xs text-gray-600 dark:text-gray-400 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        open to opportunities
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-gray-900 dark:text-white mb-6 leading-[1.1]">
        Hi, I'm Pratham. I build ML systems that
        <span class="text-primary-600 dark:text-primary-400">ship to production</span>.
      </h1>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-10 leading-relaxed max-w-2xl">
        Data Scientist with 2+ years of experience shipping production ML systems, NLP pipelines, and computer vision solutions on cloud-native infrastructure (AWS, EKS, Docker). I translate business problems into deployed AI products — and mentor the next generation of engineers along the way.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a
          href="/projects"
          class="inline-flex items-center px-6 py-3 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-medium rounded-full hover:bg-primary-600 dark:hover:bg-primary-400 transition-colors"
        >
          View My Work
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center px-6 py-3 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-medium rounded-full hover:border-primary-500 hover:text-primary-600 dark:hover:border-primary-500 dark:hover:text-primary-400 transition-colors"
        >
          Get in Touch
        </a>
        <div class="flex items-center gap-1 sm:ml-2">
          <a
            href={`https://github.com/${siteConfig.author.github}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="p-2.5 text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
          <a
            href={`https://linkedin.com/in/${siteConfig.author.linkedin}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="p-2.5 text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 py-16">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="font-mono text-sm text-primary-600 dark:text-primary-400 mb-2">01 — work</p>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Featured Projects</h2>
        </div>
        <a href="/projects" class="group font-mono text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          view all <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            slug={project.slug}
            featured={project.data.featured}
            image={project.data.image}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Latest Blog Posts -->
  {latestPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 py-16">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="font-mono text-sm text-primary-600 dark:text-primary-400 mb-2">02 — writing</p>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Latest Posts</h2>
        </div>
        <a href="/blog" class="group font-mono text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          read all <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
        </a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.slug}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    <div class="relative overflow-hidden rounded-3xl bg-gray-900 border border-gray-800 px-8 py-16 md:px-16 md:py-20 text-center">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -top-24 left-1/2 -translate-x-1/2 h-72 w-[36rem] rounded-full bg-primary-500/20 blur-3xl"
      >
      </div>
      <div class="relative">
        <p class="font-mono text-sm text-primary-400 mb-4">// get in touch</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-4">Let's build something together</h2>
        <p class="text-gray-400 mb-8 max-w-xl mx-auto">
          I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-6 py-3 bg-white text-gray-900 font-medium rounded-full hover:bg-primary-400 transition-colors"
        >
          Get in Touch
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
