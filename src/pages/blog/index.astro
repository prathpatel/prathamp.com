---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostRow from "../../components/PostRow.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || (a.data.order ?? 0) - (b.data.order ?? 0));
---

<BaseLayout title="Blog" description="Thoughts, tutorials, and insights on software development.">
  <section class="max-w-3xl mx-auto px-4 pt-14 md:pt-20 pb-12">
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3">
      <span class="mr-4">2</span>Writing
    </h1>
    <p class="italic text-gray-600 dark:text-gray-400 mb-8 max-w-2xl">
      Breaking down research papers, deriving ideas from scratch, and making complex topics intuitive.
    </p>

    <h2 class="text-lg font-bold text-gray-900 dark:text-white border-b border-gray-900 dark:border-gray-100 pb-2 mb-3">References</h2>
    <div>
      {posts.map((post, i) => (
        <PostRow
          title={post.data.title}
          date={post.data.date}
          slug={post.slug}
          tags={post.data.tags}
          refIndex={i + 1}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-500 dark:text-gray-400">No posts yet. Check back soon!</p>
      </div>
    )}
  </section>
</BaseLayout>
