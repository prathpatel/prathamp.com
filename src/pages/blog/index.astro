---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostRow from "../../components/PostRow.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || (a.data.order ?? 0) - (b.data.order ?? 0));
---

<BaseLayout title="Blog" description="Thoughts, tutorials, and insights on software development.">
  <section class="max-w-6xl mx-auto px-4 pt-16 md:pt-24 pb-16">
    <p class="font-mono text-sm text-primary-600 dark:text-primary-400 mb-4">(02) — writing</p>
    <h1 class="font-display font-bold uppercase tracking-tighter leading-none text-gray-900 dark:text-white text-5xl md:text-8xl mb-6">
      Writing<span class="text-primary-600 dark:text-primary-400">.</span>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 mb-12 md:mb-16 max-w-2xl">
      Breaking down research papers, deriving ideas from scratch, and making complex topics intuitive.
    </p>

    <div class="border-t-2 border-gray-900 dark:border-gray-100">
      {posts.map((post) => (
        <PostRow
          title={post.data.title}
          date={post.data.date}
          slug={post.slug}
          tags={post.data.tags}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-500 dark:text-gray-400">No posts yet. Check back soon!</p>
      </div>
    )}
  </section>
</BaseLayout>
