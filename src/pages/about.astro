---
import BaseLayout from "../layouts/BaseLayout.astro";
import Timeline from "../components/Timeline.astro";
import { siteConfig } from "../config/site";

const experience = [
  {
    title: "Data Scientist",
    company: "Bacancy Technology",
    location: "Ahmedabad, Gujarat",
    period: "Jul 2024 – Present",
    type: "work" as const,
    highlights: [
      "Co-developed enterprise no-code ML platform with a cross-functional team of 10–15 engineers; owned the time series forecasting module — automated 7+ manual preprocessing steps including data shaping, feature engineering, and model selection, reducing baseline development time by 80%",
      "Architected and deployed AI meeting intelligence system using AssemblyAI for transcription and GPT-4 for summarization, action-item extraction, and decision logging — integrated with Google Calendar and Drive APIs to automate end-to-end documentation workflows, saving 3+ hours weekly",
      "Led a cohort of 7 CS interns as their primary technical mentor — owned the onboarding curriculum, designed and delivered architecture training sessions on cloud-native AI platform design, and drove weekly progress reviews that accelerated ramp-up time by 50%",
    ],
  },
  {
    title: "Data Science Intern",
    company: "Bacancy Technology",
    location: "Ahmedabad, Gujarat",
    period: "Jan 2024 – Jun 2024",
    type: "work" as const,
    highlights: [
      "Developed YOLOv8-based computer vision system for manufacturing defect detection, achieving 70% accuracy on metal surface anomalies — enabled automated quality control for production line inspection across varying lighting conditions and defect types",
      "Improved model robustness through systematic hyperparameter optimization using grid search and Bayesian tuning, increasing detection reliability across edge cases and reducing false positive rate",
    ],
  },
  {
    title: "B.Tech in Computer Engineering",
    company: "Charotar University of Science and Technology",
    location: "Anand, Gujarat",
    period: "Dec 2020 – May 2024",
    type: "education" as const,
    description: "Focused on computer science fundamentals, machine learning, and software development.",
  },
];

const skills = [
  { category: "Languages", items: ["Java", "Python", "C/C++"] },
  { category: "Frameworks", items: ["LangChain", "Streamlit", "Flask", "FastAPI", "Ultralytics"] },
  { category: "Developer Tools", items: ["Git", "AWS", "VS Code", "Hugging Face", "MongoDB", "Docker", "K9S", "Grafana", "Postman"] },
  { category: "Libraries", items: ["PySpark", "Pandas", "NumPy", "PyTorch", "TensorFlow", "Keras", "Scikit-learn", "OpenCV", "FAISS", "NLTK", "SpaCy"] },
  { category: "Leadership & Mentoring", items: ["Team Leadership", "Technical Training Design", "Code Review Ownership", "Intern Program Management"] },
];
---

<BaseLayout title="About" description="Learn more about me and my journey as a developer.">
  <section class="px-4 md:px-10 pt-16 md:pt-24 pb-16">
    <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-primary-600 dark:text-primary-400 mb-4">— about</p>
    <h1 class="font-bold tracking-tight leading-none text-gray-900 dark:text-white text-5xl md:text-8xl mb-10 md:mb-14">
      About Me<span class="inline-block w-[0.13em] h-[0.13em] ml-[0.08em] bg-primary-600" aria-hidden="true"></span>
    </h1>

    <div class="prose prose-lg prose-gray dark:prose-invert max-w-3xl mb-16 border-t border-gray-900 dark:border-gray-100 pt-8">
      <p>
        Hey there! I'm {siteConfig.name}, a Data Scientist with 2+ years of experience building
        production ML systems, NLP applications, and computer vision solutions. I'm skilled at
        translating business problems into deployed AI products that drive measurable efficiency
        gains for enterprise clients.
      </p>
      <p>
        Beyond building systems, I'm passionate about growing people. I've led a cohort of 7 CS
        interns as their primary technical mentor — owning the onboarding curriculum, designing
        architecture training sessions on cloud-native AI platform design, and driving weekly
        progress reviews that accelerated intern ramp-up time by 50%. I set engineering standards
        and code review practices that were adopted across junior team members.
      </p>
      <p>
        On the technical side, I've co-developed an enterprise no-code ML platform with a
        cross-functional team of 10–15 engineers, built AI-powered meeting assistants that save
        teams 3+ hours weekly, and deployed solutions across Fortune 500 organizations. I hold a
        B.Tech in Computer Engineering from Charotar University of Science and Technology (2020-2024).
      </p>
    </div>

    <!-- Experience Timeline -->
    <div class="mb-16">
      <div class="flex items-baseline justify-between pb-4 mb-8 border-b border-gray-900 dark:border-gray-100">
        <h2 class="font-display text-2xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white">Experience & Education</h2>
        <span class="text-[11px] font-medium uppercase tracking-[0.2em] text-primary-600 dark:text-primary-400">(01)</span>
      </div>
      <Timeline items={experience} />
    </div>

    <!-- Skills Section -->
    <div class="mb-16">
      <div class="flex items-baseline justify-between pb-4 border-b border-gray-900 dark:border-gray-100">
        <h2 class="font-display text-2xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white">Skills & Tools</h2>
        <span class="text-[11px] font-medium uppercase tracking-[0.2em] text-primary-600 dark:text-primary-400">(02)</span>
      </div>
      <div>
        {skills.map((skill) => (
          <div class="grid gap-3 md:grid-cols-12 md:gap-6 py-6 border-b border-gray-200 dark:border-gray-800">
            <h3 class="md:col-span-3 text-[11px] font-medium uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400 pt-1">
              {skill.category}
            </h3>
            <p class="md:col-span-9 font-display text-lg md:text-xl text-gray-900 dark:text-gray-100 leading-relaxed">
              {skill.items.join(" · ")}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- Resume Download -->
    <a
      href="/Pratham_Patel_Resume.pdf"
      download
      class="group flex items-baseline justify-between gap-4 py-8 border-y border-gray-900 dark:border-gray-100"
    >
      <div>
        <h2 class="font-display text-2xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-white transition-all duration-300 group-hover:text-primary-600 dark:group-hover:text-primary-400">
          Download Resume
        </h2>
        <p class="mt-2 text-gray-600 dark:text-gray-400">
          A complete overview of my experience and skills, in one PDF.
        </p>
      </div>
      <svg
        class="w-7 h-7 shrink-0 text-gray-300 dark:text-gray-700 transition-all duration-300 group-hover:text-primary-600 dark:group-hover:text-primary-400"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-5-5m5 5l5-5M5 20h14" />
      </svg>
    </a>
  </section>
</BaseLayout>
