---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectRow from "../../components/ProjectRow.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout title="Projects" description="A showcase of my work and side projects.">
  <section class="px-4 md:px-10 pt-16 md:pt-24 pb-16">
    <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-primary-600 dark:text-primary-400 mb-4">(01) — work</p>
    <h1 class="font-bold tracking-tight leading-none text-gray-900 dark:text-white text-5xl md:text-8xl mb-6">
      Projects<span class="inline-block w-[0.13em] h-[0.13em] ml-[0.08em] bg-primary-600" aria-hidden="true"></span>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 mb-12 md:mb-16 max-w-2xl">
      A collection of projects I've built. Each one taught me something new.
    </p>

    <div class="border-t border-gray-900 dark:border-gray-100">
      {projects.map((project, i) => (
        <ProjectRow
          title={project.data.title}
          description={project.data.description}
          tech={project.data.tech}
          slug={project.slug}
          index={String(i + 1).padStart(2, "0")}
        />
      ))}
    </div>

    {projects.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-500 dark:text-gray-400">No projects yet. Check back soon!</p>
      </div>
    )}
  </section>
</BaseLayout>
