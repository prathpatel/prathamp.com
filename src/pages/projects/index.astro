---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectRow from "../../components/ProjectRow.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout title="Projects" description="A showcase of my work and side projects.">
  <section class="max-w-3xl mx-auto px-4 pt-14 md:pt-20 pb-12">
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3">
      <span class="mr-4">1</span>Projects
    </h1>
    <p class="italic text-gray-600 dark:text-gray-400 mb-8 max-w-2xl">
      A collection of projects I've built. Each one taught me something new.
    </p>

    <div class="divide-y divide-gray-200 dark:divide-gray-800 border-t border-gray-900 dark:border-gray-100">
      {projects.map((project, i) => (
        <ProjectRow
          title={project.data.title}
          description={project.data.description}
          tech={project.data.tech}
          slug={project.slug}
          index={`1.${i + 1}`}
        />
      ))}
    </div>

    {projects.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-500 dark:text-gray-400">No projects yet. Check back soon!</p>
      </div>
    )}
  </section>
</BaseLayout>
