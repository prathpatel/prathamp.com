---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
import { siteConfig } from "../config/site";
import { isNavItemActive } from "../utils/isNavItemActive";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  showScrollProgress?: boolean;
  progressTarget?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const {
  title,
  description,
  image,
  type = "website",
  showScrollProgress = false,
  progressTarget = "article",
  publishedTime,
  modifiedTime,
  tags,
} = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.name}` : siteConfig.title;
const pageDescription = description || siteConfig.description;
const canonicalURL = new URL(Astro.url.pathname, siteConfig.url);
const ogImage = image ? new URL(image, siteConfig.url).href : new URL("/og/default.png", siteConfig.url).href;
const currentPath = Astro.url.pathname;
const isArticle = type === "article";
const isHome = Astro.url.pathname === "/";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteConfig.author.name,
  url: siteConfig.url,
  email: `mailto:${siteConfig.author.email}`,
  sameAs: [
    `https://github.com/${siteConfig.author.github}`,
    `https://www.linkedin.com/in/${siteConfig.author.linkedin}`,
    `https://twitter.com/${siteConfig.author.twitter}`,
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.name,
  url: siteConfig.url,
  description: siteConfig.description,
  author: { "@type": "Person", name: siteConfig.author.name },
};

const articleSchema = isArticle
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description: pageDescription,
      image: ogImage,
      url: canonicalURL.href,
      datePublished: publishedTime?.toISOString(),
      dateModified: (modifiedTime ?? publishedTime)?.toISOString(),
      keywords: tags?.join(", "),
      author: {
        "@type": "Person",
        name: siteConfig.author.name,
        url: siteConfig.url,
      },
      mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL.href },
    }
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="author" content={siteConfig.author.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="en_US" />
    {isArticle && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {isArticle && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}
    {isArticle && (
      <meta property="article:author" content={siteConfig.author.name} />
    )}
    {isArticle && tags && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content={`@${siteConfig.author.twitter}`} />
    <meta name="twitter:site" content={`@${siteConfig.author.twitter}`} />

    <!-- JSON-LD structured data -->
    {isHome && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    )}
    {isHome && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    )}
    {articleSchema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    )}
    <link rel="alternate" type="application/rss+xml" title={siteConfig.name + " | Blog"} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous">
    <title>{pageTitle}</title>
    <script is:inline>
      // Apply saved theme or system preference
      (function() {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');

        function applyTheme() {
          const saved = localStorage.getItem('theme');
          if (saved === 'dark' || (!saved && prefersDark.matches)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        }

        // Apply theme immediately
        applyTheme();

        // Listen for system preference changes (only if no saved preference)
        prefersDark.addEventListener('change', (e) => {
          if (!localStorage.getItem('theme')) {
            if (e.matches) {
              document.documentElement.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
            }
          }
        });
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header showScrollProgress={showScrollProgress} progressTarget={progressTarget} />
    <!-- Mobile menu - outside header to avoid stacking context issues -->
    <div
      id="mobile-menu"
      class="hidden fixed inset-x-0 top-[57px] bottom-0 bg-white dark:bg-gray-950 z-[100] md:hidden overflow-y-auto"
    >
      <nav class="flex flex-col px-4 py-6">
        {
          siteConfig.nav.map((item, i) => {
            const isActive = isNavItemActive(currentPath, item.href);
            return (
              <a
                href={item.href}
                class:list={[
                  "flex items-baseline justify-between py-4 text-2xl font-semibold tracking-tight border-b border-gray-200 dark:border-gray-800 transition-colors",
                  isActive
                    ? "text-primary-600 dark:text-primary-400"
                    : "text-gray-900 dark:text-gray-100 hover:text-primary-600 dark:hover:text-primary-400",
                ]}
              >
                {item.name}
                <span class="text-[11px] font-medium tracking-[0.2em] text-gray-400 dark:text-gray-600">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </a>
            );
          })
        }
      </nav>
    </div>
    <main class="flex-1 flex flex-col">
      <!-- Swiss grid rails: continuous hairlines framing all page content -->
      <div class="mx-auto w-full max-w-6xl flex-1 border-x border-gray-200 dark:border-gray-800">
        <slot />
      </div>
    </main>
    <BackToTop />
    <Footer />
  </body>
</html>
