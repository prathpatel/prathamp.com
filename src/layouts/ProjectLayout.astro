---
import BaseLayout from "./BaseLayout.astro";
import Tag from "../components/Tag.astro";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    tech: string[];
    github?: string;
    live?: string;
    image?: string;
  };
  slug: string;
}

const { frontmatter, slug } = Astro.props;
const ogImage = `/og/projects/${slug}.png`;
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={ogImage}
  type="article"
  showScrollProgress={true}
>
  <article class="max-w-4xl mx-auto px-4 py-16">
    <header class="mb-12 text-center">
      <p class="text-sm italic text-primary-600 dark:text-primary-400 mb-4">Project report</p>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight text-gray-900 dark:text-white mb-5 [text-wrap:balance]">
        {frontmatter.title}
      </h1>
      <div class="mx-auto max-w-xl text-left mb-5">
        <p class="text-justify [hyphens:auto] leading-relaxed text-gray-800 dark:text-gray-200">
          <span class="font-bold">Abstract.</span> {frontmatter.description}
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-x-2 gap-y-1 mb-7">
        {frontmatter.tech.map((t) => <Tag name={t} size="sm" basePath="/projects/tags" />)}
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {
          frontmatter.github && (
            <a
              href={frontmatter.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-sm italic bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-none hover:bg-primary-600 dark:hover:bg-primary-400 transition-colors"
            >
              <svg
                class="w-4 h-4"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  clip-rule="evenodd"
                />
              </svg>
              View Code
            </a>
          )
        }
        {
          frontmatter.live && (
            <a
              href={frontmatter.live}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-sm italic border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 rounded-none hover:border-primary-500 hover:text-primary-600 dark:hover:border-primary-500 dark:hover:text-primary-400 transition-colors"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
              Live Demo
            </a>
          )
        }
      </div>
      <div class="mt-8 border-b border-gray-900 dark:border-gray-100" aria-hidden="true"></div>
    </header>
    {
      frontmatter.image && (
        <img
          src={frontmatter.image}
          alt={frontmatter.title}
          class="w-full rounded-none mb-12 border border-gray-200 dark:border-gray-800"
        />
      )
    }
    <div
      class="prose prose-lg prose-gray dark:prose-invert max-w-none prose-headings:font-semibold prose-a:text-primary-600 dark:prose-a:text-primary-400"
    >
      <slot />
    </div>
  </article>
</BaseLayout>
